# ─── Frontend (exposé au navigateur, préfixe VITE_) ───────────────────────
# URL de votre projet Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://<votre-projet>.supabase.co
# Clé publique "anon" / publishable (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=<votre-cle-anon-publishable>

# Clé PUBLIQUE FedaPay (pk_sandbox_... en test, pk_live_... en prod) — sert à
# ouvrir la fenêtre de paiement checkout.js dans le navigateur.
VITE_FEDAPAY_PUBLIC_KEY=pk_live_xxxxxxxxxxxx
# Environnement FedaPay côté client : "sandbox" (défaut) ou "live"
VITE_FEDAPAY_ENVIRONMENT=live

# ─── Secrets FedaPay — À DÉFINIR CÔTÉ SUPABASE UNIQUEMENT ──────────────────
# NE PAS mettre ces valeurs dans le frontend. Les déclarer via :
#   supabase secrets set FEDAPAY_SECRET_KEY=... FEDAPAY_ENVIRONMENT=sandbox
# (ou dans Dashboard → Edge Functions → Secrets)
#
# FEDAPAY_SECRET_KEY=sk_sandbox_xxxx     # clé SECRÈTE (création/vérif. transaction)
# FEDAPAY_ENVIRONMENT=sandbox            # "sandbox" ou "live"
# FEDAPAY_WEBHOOK_SECRET=wh_sandbox_xxxx # secret du webhook (X-FEDAPAY-SIGNATURE)
# FRONTEND_URL=https://votre-site.com    # base du callback_url

# ─── Secrets CinetPay (ancienne intégration, optionnelle) ─────────────────
# CINETPAY_APIKEY=...
# CINETPAY_SITE_ID=...
# CINETPAY_SECRET_KEY=...        # (HMAC, pour vérifier les notifications)
